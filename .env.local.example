# ── Supabase ──────────────────────────────────────────────────────────────────
# Find these in your Supabase project → Settings → API

# Project URL (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co

# Anon / public key (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# Service-role key — bypasses Row Level Security. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# ── Google Gemini ──────────────────────────────────────────────────────────────
# https://aistudio.google.com/app/apikey
# Server-side only — NEVER expose to the client.
GEMINI_API_KEY=<your-gemini-api-key>
